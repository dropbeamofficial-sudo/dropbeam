{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "." }
    }
  ],
  "routes": [
    { "src": "/_env.js", "headers": { "cache-control": "no-cache, no-store, must-revalidate" } },
    { "src": "/(.*\\..+)", "dest": "/$1" },
    { "src": "^/admin$", "dest": "/admin.html" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
